@model wacdoprojet.Models.Poste

@{
    ViewData["Title"] = "Suppression";
}

<h1>Suppression poste</h1>

@if (TempData["ErreurSuppression"] != null)
{
    <div class="alert alert-warning">
        @TempData["ErreurSuppression"]
    </div>
}


<h3>Etes vous certain de vouloir supprimer ce poste ?</h3>
<div>
    <h4>Poste</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Intituleposte)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Intituleposte)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Retour à la liste </a>
    </form>
</div>
